# Required for auth
# Generate a long random string (e.g. `openssl rand -base64 48`)
SESSION_SECRET=

# Add as many authorized users as you need by incrementing the index.
# Generate bcrypt hashes with `npx bcryptjs <password>` or an equivalent tool.
# IMPORTANT: escape every `$` in the hash value, e.g. "\$2b\$10\$..."
AUTH_USER_1_EMAIL=
AUTH_USER_1_PASSWORD_HASH=
# AUTH_USER_2_EMAIL=
# AUTH_USER_2_PASSWORD_HASH=

# Database (Postgres). At minimum DATABASE_URL is required.
# DATABASE_URL_UNPOOLED is used by Prisma for migrations when available.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Blob storage for larger direct-upload audio (Vercel Blob).
# Required if you want the Gemini background workflow path for files > ~20 MB.
BLOB_READ_WRITE_TOKEN=

# Distributed rate limiter (optional). When both values are set the app uses
# Upstash Redis for login/upload/transcription rate limits; otherwise it
# falls back to an in-memory limiter per Fluid Compute instance. Provision
# via Vercel Marketplace → Upstash Redis; the env vars will be injected.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional override for the direct-upload size ceiling. Defaults to 524288000 (500 MB).
BLOB_AUDIO_MAX_BYTES=

# Transcription provider keys (configure at least one).
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
# Optional: point at a self-hosted faster-whisper compatible HTTP endpoint.
WHISPER_API_URL=

# Summarization (OpenRouter). Required for the structured case brief.
# The OPENROUTER_API_KEY above is reused for summaries.
SUMMARY_MODEL=anthropic/claude-3.5-haiku

# Model overrides (optional).
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
GEMINI_TRANSCRIPTION_MODEL=gemini-2.5-flash
VOXTRAL_TRANSCRIPTION_MODEL=mistralai/voxtral-small-24b-2507

# Preferred default provider when multiple are configured (gemini | voxtral-openrouter | openai | whisper-local)
DEFAULT_TRANSCRIPTION_PROVIDER=gemini
