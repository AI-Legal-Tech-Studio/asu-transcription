# Credentials and tokens (AGENTS.md: never commit)
config/google_credentials.json
config/google_token.json
config/*.json
!config/.gitkeep

# Python (kept minimal — this is a Node/Next.js project)
__pycache__/
*.py[cod]
.venv/
venv/

# Logs and runtime (AGENTS.md: logs/ for debugging)
logs/
.local-data/
*.log
.pytest_cache/
.coverage
htmlcov/

